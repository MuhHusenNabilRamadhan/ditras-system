{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "index.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    {
      "source": "/api/cek-ketersediaan",
      "destination": "/api/cek-ketersediaan.php"
    },
    { "source": "/", "destination": "/index.php" }
  ]
}
